{"ast":null,"code":"import{useState,useEffect}from'react';const ScrollListener=_ref=>{let{onScroll}=_ref;const[scrollPercentage,setScrollPercentage]=useState(0);useEffect(()=>{const handleScroll=()=>{const scrollTop=window.pageYOffset||document.documentElement.scrollTop;const scrollHeight=document.documentElement.scrollHeight-document.documentElement.clientHeight;const percentage=scrollTop/scrollHeight*100;setScrollPercentage(percentage);onScroll(percentage);};window.addEventListener('scroll',handleScroll);return()=>{window.removeEventListener('scroll',handleScroll);};},[onScroll]);return null;};export default ScrollListener;","map":{"version":3,"names":["useState","useEffect","ScrollListener","_ref","onScroll","scrollPercentage","setScrollPercentage","handleScroll","scrollTop","window","pageYOffset","document","documentElement","scrollHeight","clientHeight","percentage","addEventListener","removeEventListener"],"sources":["D:/federicogarciabarreiro.github.io/src/components/ScrollListener.js"],"sourcesContent":["import { useState, useEffect } from 'react';\r\n\r\nconst ScrollListener = ({ onScroll }) => {\r\n  const [scrollPercentage, setScrollPercentage] = useState(0);\r\n\r\n  useEffect(() => {\r\n    const handleScroll = () => {\r\n      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;\r\n      const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;\r\n      const percentage = (scrollTop / scrollHeight) * 100;\r\n      setScrollPercentage(percentage);\r\n      onScroll(percentage);\r\n    };\r\n\r\n    window.addEventListener('scroll', handleScroll);\r\n\r\n    return () => {\r\n      window.removeEventListener('scroll', handleScroll);\r\n    };\r\n  }, [onScroll]);\r\n\r\n  return null;\r\n};\r\n\r\nexport default ScrollListener;\r\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,KAAM,CAAAC,cAAc,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CAClC,KAAM,CAACE,gBAAgB,CAAEC,mBAAmB,C